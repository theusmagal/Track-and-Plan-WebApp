{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://track-and-plan-webapp-production.up.railway.app/api/$1"
    }
  ],
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    }
  ]
}
