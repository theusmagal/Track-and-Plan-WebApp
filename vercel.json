{
  "proxies": [
    {
      "source": "/api/:match*",
      "destination": "https://track-and-plan-webapp-production.up.railway.app/api/:match*"
    }
  ],
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    }
  ]
}
